# Configuração de Variáveis de Ambiente
# Renomeie este arquivo para .env e preencha com seus valores

# Segredo para assinar JWT (use uma string longa e aleatória)
JWT_SECRET=seu_segredo_super_seguro_aqui_minimo_32_caracteres_aleatorios

# Porta do servidor
PORT=3000

# Ambiente de execução (development, production)
NODE_ENV=development

# Caminho do banco de dados SQLite
DATABASE_PATH=./estoque.db

# Tempo de expiração do token (ex: 24h, 7d, 30d)
TOKEN_EXPIRATION=24h

# Debug mode (true para ativar logs detalhados)
DEBUG=false
